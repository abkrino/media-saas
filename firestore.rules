rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: brands
    // Fields: name, niche, market, website, socials, competitors, brandVoice, targetAudience, mainProducts, logoUrl, assetUrls, createdAt, ownerId
    //
    // Collection: brand_research
    // Fields: brandId, summary, positioning, audienceInsights, toneOfVoice, visualDirection, competitorNotes, contentOpportunities, campaignAngle, recommendedOffer, updatedAt
    //
    // Collection: brand_assets
    // Fields: brandId, fileUrl, fileName, fileType, assetCategory, productName, tags, orientation, recommendedUsage, createdAt, ownerId
    //
    // Collection: connected_channels
    // Fields: brandId, platform, status, accountName, accountId, lastSync, ownerId
    //
    // Collection: publishing_jobs
    // Fields: brandId, platforms, content, mediaUrls, scheduledFor, publishedAt, status, ownerId
    //
    // Collection: whatsapp_messages
    // Fields: conversationId, customerWaId, direction, messageType, content, metaMessageId, rawPayload, createdAt, ownerId
    //
    // Collection: campaign_briefs
    // Fields: brandId, campaignId, objective, offer, audience, heroProduct, secondaryProducts, platforms, deliverables, tone, deadline, status, createdAt, ownerId
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isBrandOwner(brandId) {
      return isAuthenticated() && get(/databases/$(database)/documents/brands/$(brandId)).data.ownerId == request.auth.uid;
    }

    // Brands
    match /brands/{brandId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Research
    match /brand_research/{brandId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid || isBrandOwner(brandId));
      allow create: if isAuthenticated() && (request.resource.data.ownerId == request.auth.uid || isBrandOwner(brandId));
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isBrandOwner(brandId));
    }

    // Assets
    match /brand_assets/{assetId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Channels
    match /connected_channels/{channelId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Publishing
    match /publishing_jobs/{jobId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // AI Agents
    match /ai_agents/{agentId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Agent Tasks
    match /agent_tasks/{taskId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Task Outputs
    match /task_outputs/{outputId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // WhatsApp Channels
    match /whatsapp_channels/{channelId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // WhatsApp Conversations
    match /whatsapp_conversations/{conversationId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // WhatsApp Messages
    match /whatsapp_messages/{messageId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Campaign Briefs
    match /campaign_briefs/{briefId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId);
    }

    // Webhook Logs (for debugging)
    match /webhook_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // Deliverables
    match /deliverables/{deliverableId} {
      allow read: if isOwner(resource.data.ownerId);
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(resource.data.ownerId);
      allow delete: if isOwner(resource.data.ownerId);
    }

    // Deliverable Feedback
    match /deliverable_feedback/{feedbackId} {
      allow read: if isAuthenticated(); // Simplified for now, should ideally check deliverable ownership
      allow create: if isAuthenticated();
    }

    // Deliverable Versions
    match /deliverable_versions/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
  }
}
